APP_PORT=3000

DB_HOST=localhost
DB_PORT=3306
DB_USER=carniceria
DB_PASSWORD=CAMBIAR_EN_PRODUCCION
DB_NAME=carniceria_db
DB_ROOT_PASSWORD=CAMBIAR_EN_PRODUCCION

# Path to static files (auto-overridden in Docker)
PUBLIC_DIR=../public

# JWT (JSON Web Token) — autenticación
JWT_SECRET=genera-aqui-64-caracteres-aleatorios
JWT_EXPIRES_IN=8h
BCRYPT_ROUNDS=12

# CORS — dominio desde el que el browser puede hacer peticiones a la API.
# Ejemplo: https://tutienda.es
# Si no se define, las peticiones cross-origin quedan bloqueadas para todos los orígenes.
ALLOWED_ORIGIN=
